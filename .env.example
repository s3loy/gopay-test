# Server
GOPAY_APP_ENV=development
GOPAY_APP_DEBUG=true
GOPAY_SERVER_PORT=8080

# Database
GOPAY_DATABASE_HOST=localhost
GOPAY_DATABASE_PORT=5432
GOPAY_DATABASE_USER=gopay
GOPAY_DATABASE_PASSWORD=gopay123
GOPAY_DATABASE_DBNAME=gopay
GOPAY_DATABASE_SSLMODE=disable

# WeChat Pay
GOPAY_PAYMENT_WECHAT_ENABLED=false
GOPAY_PAYMENT_WECHAT_MCHID=
GOPAY_PAYMENT_WECHAT_SERIAL_NO=
GOPAY_PAYMENT_WECHAT_API_V3_KEY=
GOPAY_PAYMENT_WECHAT_PRIVATE_KEY_PATH=
GOPAY_PAYMENT_WECHAT_PUBLIC_KEY_PATH=
GOPAY_PAYMENT_WECHAT_PUBLIC_KEY_ID=
GOPAY_PAYMENT_WECHAT_NOTIFY_URL=https://your-domain.com/webhook/wechat/notify

# Alipay
GOPAY_PAYMENT_ALIPAY_ENABLED=false
GOPAY_PAYMENT_ALIPAY_APPID=
GOPAY_PAYMENT_ALIPAY_PRIVATE_KEY_PATH=
GOPAY_PAYMENT_ALIPAY_PUBLIC_KEY_PATH=
GOPAY_PAYMENT_ALIPAY_APP_CERT_PATH=
GOPAY_PAYMENT_ALIPAY_ROOT_CERT_PATH=
GOPAY_PAYMENT_ALIPAY_NOTIFY_URL=https://your-domain.com/webhook/alipay/notify
GOPAY_PAYMENT_ALIPAY_IS_PROD=false
